# ───────────────────────────────────────────────────────────
# Orael — Production Environment Configuration
# Copy this file to .env and fill in your values
# ───────────────────────────────────────────────────────────

# Telegram Bot
BOT_TOKEN=                    # From @BotFather

# Server
PORT=3000
NODE_ENV=production
DOMAIN=https://yourdomain.com

# Admin Telegram IDs (comma-separated) — ONLY these users can access the admin panel
# New admins can ONLY be added here, NOT from the admin panel.
# Admins can make users moderators from the panel, but cannot create new admins.
ADMIN_IDS=123456789,987654321

# Adsgram (Rewarded Ads)
VITE_ADSGRAM_BLOCK_ID=35273
VITE_ADSGRAM_TASK_BLOCK_ID=task-35279
ADSGRAM_SECRET=               # From Adsgram dashboard (for S2S callback verification)

# Flutterwave (Bank transfers + Airtime)
FLUTTERWAVE_SECRET_KEY=       # From Flutterwave dashboard (Settings > API)
FLUTTERWAVE_ENCRYPTION_KEY=   # From Flutterwave dashboard (Settings > API)
FLUTTERWAVE_PUBLIC_KEY=       # From Flutterwave dashboard (Settings > API)
FLW_SECRET_HASH=              # From Flutterwave dashboard (Settings > Webhooks) — used to verify webhook signatures
